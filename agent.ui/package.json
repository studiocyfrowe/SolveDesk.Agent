{
  "name": "agent.ui",
  "version": "0.1.0",
  "private": true,

  "main": "dist-electron/main.js",

  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@recharts/devtools": "^0.0.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.0",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },

  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",

    "electron-build": "tsc -p electron",
    "electron": "electron .",

    "dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && npm run electron\"",

    "build": "npm run react-build && npm run electron-build",
    "start": "cross-env NODE_ENV=production npm run build && npm run electron",

    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },

  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },

  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },

  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "wait-on": "^9.0.4",
    "typescript": "^4.9.5"
  }
}